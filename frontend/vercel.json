{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "rewrites": [
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Cache-Control", "value": "no-store" }
      ]
    }
  ],
  "crons": [
    {
      "path": "/api/cron/wake",
      "schedule": "0 4 * * 1-5"
    },
    {
      "path": "/api/cron/wake",
      "schedule": "30 4 * * 1-5"
    },
    {
      "path": "/api/cron/daily-scan",
      "schedule": "35 4 * * 1-5"
    },
    {
      "path": "/api/cron/wake",
      "schedule": "30 10 * * 1-5"
    }
  ]
}
