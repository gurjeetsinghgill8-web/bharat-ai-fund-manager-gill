{
  "version": 2,
  "buildCommand": "cd frontend && npm install && npm run build",
  "outputDirectory": "frontend/dist",
  "framework": "vite",
  "functions": {
    "api/**/*.py": {
      "runtime": "python3.12",
      "includeFiles": "fastapi_app/**, *.py"
    }
  },
  "rewrites": [
    { "source": "/api/cron/(.*)", "destination": "/api/cron/$1" },
    { "source": "/api/(.*)", "destination": "/api/index.py" },
    { "source": "/(.*)", "destination": "/frontend/$1" }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Cache-Control", "value": "no-store" }
      ]
    }
  ],
  "crons": [
    {
      "path": "/api/cron/wake",
      "schedule": "0 4 * * 1-5"
    },
    {
      "path": "/api/cron/wake",
      "schedule": "30 4 * * 1-5"
    },
    {
      "path": "/api/cron/daily-scan",
      "schedule": "35 4 * * 1-5"
    },
    {
      "path": "/api/cron/wake",
      "schedule": "30 10 * * 1-5"
    }
  ]
}
